@{
    ViewData["Title"] = "Success";
}

<div class="container text-center" style="margin-top: 100px;">
    <div class="card shadow-lg p-5 border-0" style="border-radius: 20px;">
        <div class="mb-4">
            <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
        </div>
        <h1 class="display-4 fw-bold text-success">تم الطلب بنجاح!</h1>
        <p class="lead text-muted">شكراً لثقتك بنا. طلبك رقم <span class="badge bg-primary">#@ViewBag.OrderId</span> قيد التنفيذ الآن.</p>

        <hr class="my-4">

        <div class="d-grid gap-2 d-md-block">
            <a href="/Home/Index" class="btn btn-outline-primary btn-lg px-5">الرئيسية</a>
            <a href="/Orders/MyOrders" class="btn btn-primary btn-lg px-5">طلباتي</a>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">