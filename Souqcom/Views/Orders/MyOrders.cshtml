@model List<Order>

<h2>طلباتي</h2>

<table class="table">
    <tr>
        <th>رقم الطلب</th>
        <th>الإجمالي</th>
        <th>الحالة</th>
        <th>التاريخ</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.TotalPrice</td>
            <td>
                @(item.Status == 0 ? "قيد المراجعة" :
                            item.Status == 1 ? "مدفوع" :
                            item.Status == 2 ? "فشل الدفع" : "ملغي")
        </td>
        <td>@item.CreatAt</td>
        <td>
            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">
                التفاصيل
            </a>
        </td>
    </tr>
        }
</table>
