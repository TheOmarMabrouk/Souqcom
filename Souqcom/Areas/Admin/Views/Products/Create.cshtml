@model First_core_project.Models.Product

@{
    ViewData["Title"] = "إضافة منتج جديد - لوحة الإدارة";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">إضافة منتج جديد للمتجر</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8 offset-md-2">
                    <form asp-action="Create" enctype="multipart/form-data" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label asp-for="Name" class="control-label font-weight-bold">اسم المنتج</label>
                                <input asp-for="Name" class="form-control" placeholder="أدخل اسم المنتج" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="form-group col-md-6">
                                <label asp-for="Price" class="control-label font-weight-bold">السعر (EGP)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label asp-for="Catid" class="control-label font-weight-bold">القسم التابع له</label>
                                <select asp-for="Catid" class="form-control" asp-items="ViewBag.Catid">
                                    <option value="">-- اختر القسم من القائمة --</option>
                                </select>
                                <span asp-validation-for="Catid" class="text-danger"></span>
                            </div>

                            <div class="form-group col-md-6">
                                <label asp-for="Type" class="control-label font-weight-bold">النوع / الموديل</label>
                                <input asp-for="Type" class="form-control" />
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Discription" class="control-label font-weight-bold">وصف المنتج</label>
                            <textarea asp-for="Discription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Discription" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label asp-for="SupplierName" class="control-label font-weight-bold">اسم المورد</label>
                                <input asp-for="SupplierName" class="form-control" />
                                <span asp-validation-for="SupplierName" class="text-danger"></span>
                            </div>

                            <div class="form-group col-md-6">
                                <label asp-for="EntryDate" class="control-label font-weight-bold">تاريخ الإضافة</label>
                                <input asp-for="EntryDate" class="form-control" type="date" />
                                <span asp-validation-for="EntryDate" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />

                        <div class="form-group bg-light p-3 border rounded">
                            <label class="control-label font-weight-bold text-success">
                                <i class="fas fa-images"></i> معرض صور المنتج (يمكنك اختيار عدة صور)
                            </label>
                            <input type="file" name="Images" class="form-control-file" multiple accept="image/*" />
                            <small class="form-text text-muted">يفضل استخدام صور عالية الجودة لزيادة المبيعات.</small>
                        </div>

                        

                        <div class="form-group text-center mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-save"></i> حفظ المنتج
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">العودة للقائمة</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}