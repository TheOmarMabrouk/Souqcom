@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">إدارة الطلبات</h5>
        <a asp-action="CancelledOrders" class="btn btn-sm btn-outline-light">الأرشيف (الملغية)</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>رقم الطلب</th>
                    <th>العميل</th>
                    <th>التاريخ</th>
                    <th>الإجمالي</th>
                    <th>حالة الدفع</th>
                    <th class="text-center">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Status == 4 ? "table-danger text-muted text-decoration-line-through" : "")">
                        <td class="fw-bold">#@item.Id</td>
                        <td>@(ViewBag.Users.ContainsKey(item.UserId) ? ViewBag.Users[item.UserId] : "عميل غير معروف")</td>
                        <td>@item.CreatAt?.ToString("yyyy-MM-dd")</td>
                        <td class="text-primary fw-bold">@((item.TotalPrice ?? 0).ToString("C"))</td>
                        <td>
                            @if (item.Status == 1)
                            {
                                <span class="badge bg-success">مدفوع</span>
                            }
                            else if (item.Status == 4)
                            {
                                <span class="badge bg-secondary">ملغي</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">قيد الانتظار</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i> التفاصيل
                            </a>
                        </td>
                    </tr>
                }
              
            </tbody>
        </table>
    </div>
</div>